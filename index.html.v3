<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title>Signal Scan — Coil Break Scanner</title>
<meta name="description" content="Live Moving-Average Compression &amp; Breakout scanner for Deriv synthetic indices, running entirely in your browser.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#0A0D13;
    --bg-grid:#0D111A;
    --panel:#121722;
    --panel-2:#161C29;
    --border:#232B3A;
    --border-soft:#1B212E;
    --text:#E7EBF2;
    --text-dim:#8D96A8;
    --text-mute:#586173;
    --buy:#33D6A6;
    --buy-dim:rgba(51,214,166,.13);
    --sell:#FF6B7E;
    --sell-dim:rgba(255,107,126,.13);
    --amber:#F2B84B;
    --amber-dim:rgba(242,184,75,.14);
    --mixed:#4B5568;
    --mixed-dim:rgba(75,85,104,.18);
    --stage-impulse:#F2B84B;
    --stage-coil:#5FA8F2;
    --stage-breakout:#C98AF2;
    --radius:10px;
    --radius-lg:16px;
    --font-display:'Space Grotesk',sans-serif;
    --font-body:'Inter',sans-serif;
    --font-mono:'JetBrains Mono',monospace;
    --shadow-1: 0 1px 0 rgba(255,255,255,.02) inset, 0 8px 24px -12px rgba(0,0,0,.6);
  }
  *{box-sizing:border-box;}
  html,body{height:100%;}
  body{
    margin:0;
    background:
      radial-gradient(1200px 600px at 85% -10%, rgba(242,184,75,.06), transparent 60%),
      radial-gradient(900px 500px at 0% 0%, rgba(51,214,166,.05), transparent 55%),
      var(--bg);
    color:var(--text);
    font-family:var(--font-body);
    -webkit-font-smoothing:antialiased;
    min-height:100vh;
  }
  ::selection{ background:var(--amber-dim); color:var(--text); }
  ::-webkit-scrollbar{ width:8px; height:8px; }
  ::-webkit-scrollbar-track{ background:transparent; }
  ::-webkit-scrollbar-thumb{ background:var(--border); border-radius:8px; }
  a{ color:inherit; }
  button, input{ font-family:inherit; }
  :focus-visible{ outline:2px solid var(--amber); outline-offset:2px; }

  /* ---------- Topbar ---------- */
  .topbar{
    position:sticky; top:0; z-index:30;
    display:flex; align-items:center; gap:16px;
    padding:14px 22px;
    background:rgba(10,13,19,.86);
    backdrop-filter:blur(10px);
    border-bottom:1px solid var(--border-soft);
  }
  .brand{
    font-family:var(--font-display); font-weight:700; letter-spacing:.02em;
    font-size:18px; display:flex; align-items:center; gap:9px; white-space:nowrap;
  }
  .brand-mark{
    display:inline-grid; place-items:center;
    width:26px; height:26px; border-radius:8px;
    background:linear-gradient(155deg, var(--amber), #C98A2E);
    color:#191207; font-size:14px; font-weight:700;
  }
  .brand .accent{ color:var(--amber); }
  .status-pill{
    display:flex; align-items:center; gap:8px;
    padding:6px 12px; border-radius:999px;
    border:1px solid var(--border);
    background:var(--panel);
    font-size:12.5px; color:var(--text-dim);
    font-family:var(--font-mono);
    white-space:nowrap;
  }
  .status-pill .dot{
    width:8px; height:8px; border-radius:50%;
    background:var(--text-mute);
    box-shadow:0 0 0 3px transparent;
  }
  .status-pill[data-state="live"] .dot{ background:var(--buy); box-shadow:0 0 0 3px var(--buy-dim); animation:pulse 1.8s ease-in-out infinite; }
  .status-pill[data-state="connecting"] .dot{ background:var(--amber); box-shadow:0 0 0 3px var(--amber-dim); animation:pulse 1s ease-in-out infinite; }
  .status-pill[data-state="reconnecting"] .dot{ background:var(--amber); box-shadow:0 0 0 3px var(--amber-dim); animation:pulse .7s ease-in-out infinite; }
  .status-pill[data-state="offline"] .dot{ background:var(--text-mute); }
  @keyframes pulse{ 0%,100%{ opacity:1; } 50%{ opacity:.35; } }
  @media (prefers-reduced-motion:reduce){ .status-pill .dot{ animation:none !important; } }

  .topbar-actions{ margin-left:auto; display:flex; align-items:center; gap:8px; }
  .btn{
    appearance:none; border:1px solid var(--border); background:var(--panel);
    color:var(--text); font-size:13.5px; font-weight:500;
    padding:9px 16px; border-radius:9px; cursor:pointer;
    transition:background .15s ease, border-color .15s ease, transform .1s ease;
  }
  .btn:hover{ background:var(--panel-2); border-color:#2c3547; }
  .btn:active{ transform:translateY(1px); }
  .btn-primary{
    background:linear-gradient(155deg, var(--amber), #C98A2E);
    color:#191207; border-color:transparent; font-weight:600;
  }
  .btn-primary:hover{ filter:brightness(1.06); background:linear-gradient(155deg, var(--amber), #C98A2E); }
  .btn-danger{ color:var(--sell); border-color:rgba(255,107,126,.35); }
  .btn-danger:hover{ background:var(--sell-dim); }
  .btn-icon{ padding:9px 11px; font-size:15px; line-height:1; }

  /* ---------- Layout ---------- */
  main{ max-width:1400px; margin:0 auto; padding:22px; }
  .toolbar{
    display:flex; flex-wrap:wrap; align-items:center; gap:12px;
    margin-bottom:18px;
  }
  .search-wrap{ position:relative; flex:1 1 220px; max-width:320px; }
  .search-wrap input{
    width:100%; background:var(--panel); border:1px solid var(--border);
    color:var(--text); border-radius:9px; padding:9px 12px 9px 32px;
    font-size:13.5px;
  }
  .search-wrap input::placeholder{ color:var(--text-mute); }
  .search-wrap svg{ position:absolute; left:10px; top:50%; transform:translateY(-50%); opacity:.5; }
  .chip-row{ display:flex; flex-wrap:wrap; gap:6px; }
  .chip{
    padding:7px 13px; border-radius:999px; font-size:12.5px; font-weight:500;
    border:1px solid var(--border); background:var(--panel); color:var(--text-dim);
    cursor:pointer; white-space:nowrap; transition:all .15s ease;
  }
  .chip:hover{ color:var(--text); }
  .chip.active{ background:var(--amber-dim); border-color:rgba(242,184,75,.4); color:var(--amber); }
  .meta-counts{ margin-left:auto; font-family:var(--font-mono); font-size:12px; color:var(--text-mute); white-space:nowrap; }

  .content-grid{ display:grid; grid-template-columns:1fr 320px; gap:20px; align-items:start; }
  @media (max-width:980px){ .content-grid{ grid-template-columns:1fr; } }

  .cards-grid{
    display:grid; grid-template-columns:repeat(auto-fill, minmax(230px,1fr));
    gap:12px;
  }
  .empty-state{
    grid-column:1/-1;
    border:1px dashed var(--border); border-radius:var(--radius-lg);
    padding:48px 24px; text-align:center; color:var(--text-dim);
  }
  .empty-state h3{ font-family:var(--font-display); color:var(--text); margin:0 0 6px; font-size:16px; }
  .empty-state p{ margin:0; font-size:13px; color:var(--text-mute); max-width:420px; margin:0 auto; }

  /* ---------- Instrument card ---------- */
  .card{
    background:var(--panel); border:1px solid var(--border); border-radius:var(--radius-lg);
    padding:14px; box-shadow:var(--shadow-1);
    transition:border-color .5s ease, box-shadow .5s ease, transform .15s ease;
    position:relative; overflow:hidden;
    cursor:pointer;
  }
  .card:not(.skeleton):hover{ border-color:#2c3547; transform:translateY(-2px); }
  .card:not(.skeleton):focus-visible{ transform:translateY(-2px); }
  .card.skeleton{ cursor:default; }
  .chart-hint{
    font-size:9.5px; color:var(--text-mute); font-family:var(--font-mono);
    text-align:right; opacity:0; transition:opacity .15s ease; margin-top:2px;
  }
  .card:not(.skeleton):hover .chart-hint{ opacity:1; color:var(--amber); }
  .card.flash-buy{ border-color:var(--buy); box-shadow:0 0 0 1px var(--buy), var(--shadow-1); }
  .card.flash-sell{ border-color:var(--sell); box-shadow:0 0 0 1px var(--sell), var(--shadow-1); }
  .card-top{ display:flex; align-items:flex-start; justify-content:space-between; gap:8px; margin-bottom:10px; }
  .card-label{ font-family:var(--font-display); font-weight:600; font-size:13.5px; line-height:1.25; }
  .card-symbol{ font-family:var(--font-mono); font-size:10.5px; color:var(--text-mute); margin-top:2px; }
  .card-price{ font-family:var(--font-mono); font-size:15px; font-weight:600; text-align:right; white-space:nowrap; }
  .badges{ display:flex; gap:6px; margin-bottom:12px; }
  .badge{
    font-family:var(--font-mono); font-size:10.5px; font-weight:600; letter-spacing:.03em;
    padding:3px 7px; border-radius:5px; text-transform:uppercase;
  }
  .badge.bullish{ color:var(--buy); background:var(--buy-dim); }
  .badge.bearish{ color:var(--sell); background:var(--sell-dim); }
  .badge.mixed{ color:var(--text-mute); background:var(--mixed-dim); }

  .cascade{ display:flex; align-items:center; gap:4px; margin-bottom:8px; }
  .cascade .stage{
    flex:1; height:5px; border-radius:3px; background:var(--border-soft);
    position:relative; overflow:hidden;
  }
  .cascade .stage.on{ background:var(--stage-impulse); }
  .cascade .stage.s2.on{ background:var(--stage-coil); }
  .cascade .stage.s3.on{ background:var(--stage-breakout); }
  .cascade .stage.on.buy{ background:var(--buy); }
  .cascade .stage.on.sell{ background:var(--sell); }
  .cascade .stage.armed{ animation:armedGlow 1.1s ease-in-out infinite; }
  @keyframes armedGlow{ 0%,100%{ opacity:1; } 50%{ opacity:.45; } }
  @media (prefers-reduced-motion:reduce){ .cascade .stage.armed{ animation:none; } }

  .cascade-labels{ display:flex; justify-content:space-between; font-size:9.5px; color:var(--text-mute); font-family:var(--font-mono); text-transform:uppercase; letter-spacing:.03em; margin-bottom:6px; }
  .card-footer{ display:flex; justify-content:space-between; align-items:center; font-size:11px; color:var(--text-mute); font-family:var(--font-mono); }
  .card-status-text{ font-size:11.5px; }
  .card-status-text.buy{ color:var(--buy); }
  .card-status-text.sell{ color:var(--sell); }
  .card.skeleton .badge, .card.skeleton .card-price{ color:var(--text-mute); }

  /* ---------- Feed panel ---------- */
  .feed-panel{
    background:var(--panel); border:1px solid var(--border); border-radius:var(--radius-lg);
    padding:16px; position:sticky; top:78px; max-height:calc(100vh - 100px); display:flex; flex-direction:column;
  }
  .feed-panel h2{ font-family:var(--font-display); font-size:14px; margin:0 0 4px; display:flex; align-items:center; gap:8px; }
  .feed-panel h2 .count{ font-family:var(--font-mono); font-size:11px; color:var(--text-mute); font-weight:400; }
  .feed-sub{ font-size:11.5px; color:var(--text-mute); margin:0 0 12px; }
  .feed-list{ overflow-y:auto; display:flex; flex-direction:column; gap:8px; padding-right:2px; }
  .feed-empty{ color:var(--text-mute); font-size:12.5px; padding:20px 0; text-align:center; }
  .feed-item{
    border:1px solid var(--border); border-left-width:3px; border-radius:8px;
    padding:9px 10px; background:var(--panel-2);
    animation:slideIn .25s ease;
  }
  @keyframes slideIn{ from{ opacity:0; transform:translateY(-6px); } to{ opacity:1; transform:none; } }
  @media (prefers-reduced-motion:reduce){ .feed-item{ animation:none; } }
  .feed-item.preview{ border-left-color:var(--amber); }
  .feed-item.buy{ border-left-color:var(--buy); }
  .feed-item.sell{ border-left-color:var(--sell); }
  .feed-item.timeout{ border-left-color:var(--text-mute); }
  .feed-row1{ display:flex; justify-content:space-between; gap:8px; font-size:12.5px; font-weight:600; }
  .feed-row1 .tag{ font-family:var(--font-mono); font-size:10px; padding:1px 6px; border-radius:4px; text-transform:uppercase; }
  .feed-item.preview .tag{ color:var(--amber); background:var(--amber-dim); }
  .feed-item.buy .tag{ color:var(--buy); background:var(--buy-dim); }
  .feed-item.sell .tag{ color:var(--sell); background:var(--sell-dim); }
  .feed-row1 .tag.won{ color:var(--buy); background:var(--buy-dim); }
  .feed-row1 .tag.lost{ color:var(--sell); background:var(--sell-dim); }
  .feed-row1 .tag.timeout{ color:var(--text-mute); background:var(--mixed-dim); }
  .feed-row2{ font-family:var(--font-mono); font-size:11px; color:var(--text-mute); margin-top:4px; display:flex; justify-content:space-between; }
  .feed-row3{ font-family:var(--font-mono); font-size:10.5px; color:var(--text-mute); margin-top:3px; display:flex; justify-content:space-between; }
  .feed-row3 .tp{ color:var(--buy); }
  .feed-row3 .sl{ color:var(--sell); }

  .card-position{
    display:flex; justify-content:space-between; margin-top:10px; padding-top:9px;
    border-top:1px dashed var(--border-soft); font-family:var(--font-mono); font-size:10.5px; color:var(--text-mute);
  }
  .card-position .tp{ color:var(--buy); }
  .card-position .sl{ color:var(--sell); }

  /* ---------- Toasts ---------- */
  .toast-container{ position:fixed; bottom:18px; right:18px; z-index:100; display:flex; flex-direction:column; gap:8px; max-width:320px; }
  .toast{
    background:var(--panel-2); border:1px solid var(--border); border-left:3px solid var(--amber);
    padding:11px 14px; border-radius:8px; font-size:12.5px; box-shadow:var(--shadow-1);
    animation:slideIn .25s ease;
  }
  .toast.error{ border-left-color:var(--sell); }
  .toast.success{ border-left-color:var(--buy); }

  /* ---------- Modal ---------- */
  .modal-overlay{
    position:fixed; inset:0; background:rgba(6,8,12,.72); backdrop-filter:blur(3px);
    display:flex; align-items:center; justify-content:center; z-index:200; padding:16px;
  }
  .modal-overlay[hidden]{ display:none !important; }
  .modal{
    background:var(--panel); border:1px solid var(--border); border-radius:var(--radius-lg);
    width:100%; max-width:460px; max-height:88vh; overflow-y:auto; padding:22px;
    box-shadow:0 20px 60px -20px rgba(0,0,0,.7);
  }
  .modal h2{ font-family:var(--font-display); font-size:17px; margin:0 0 4px; }
  .modal .modal-sub{ font-size:12.5px; color:var(--text-mute); margin:0 0 18px; }
  .field-group{ margin-bottom:16px; }
  .field-group legend, .field-label{ font-size:11.5px; font-weight:600; color:var(--text-dim); text-transform:uppercase; letter-spacing:.03em; margin-bottom:8px; display:block; }
  .field-row{ display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:10px; }
  .field{ display:flex; flex-direction:column; gap:4px; }
  .field label{ font-size:11.5px; color:var(--text-mute); }
  .field input[type="text"], .field input[type="number"], .field input[type="password"], .field select{
    background:var(--panel-2); border:1px solid var(--border); color:var(--text);
    padding:8px 10px; border-radius:7px; font-size:13px; font-family:var(--font-mono); width:100%;
  }
  .field select{ font-family:inherit; cursor:pointer; }
  .checkbox-row{ display:flex; align-items:center; gap:9px; margin-bottom:10px; font-size:13px; }
  .checkbox-row input{ width:16px; height:16px; accent-color:var(--amber); }
  .sound-style-inline{ display:flex; gap:6px; align-items:center; }
  .sound-style-inline select{ flex:1; }
  .sound-style-inline .btn-test{ padding:8px 10px; font-size:12px; flex-shrink:0; }
  .divider{ height:1px; background:var(--border-soft); margin:16px 0; }
  .modal-actions{ display:flex; justify-content:flex-end; gap:8px; margin-top:6px; }
  .hint{ font-size:11px; color:var(--text-mute); margin-top:6px; line-height:1.5; }

  @media (max-width:640px){
    .topbar{ padding:12px 14px; gap:10px; flex-wrap:wrap; }
    .brand{ font-size:16px; }
    main{ padding:14px; }
    .content-grid{ gap:14px; }
    .feed-panel{ position:static; max-height:none; }
    .meta-counts{ display:none; }
  }
</style>
</head>
<body>

<header class="topbar">
  <div class="brand"><span class="brand-mark">◐</span>SIGNAL<span class="accent">SCAN</span></div>
  <div class="status-pill" id="statusPill" data-state="offline"><span class="dot"></span><span id="statusText">Offline</span></div>
  <div class="topbar-actions">
    <button id="startBtn" class="btn btn-primary">Start scanning</button>
    <button id="stopBtn" class="btn btn-danger" hidden>Stop</button>
    <button id="settingsBtn" class="btn btn-icon" aria-label="Open settings" title="Settings">⚙</button>
  </div>
</header>

<main>
  <section class="toolbar">
    <div class="search-wrap">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
      <input id="searchInput" type="text" placeholder="Filter instruments…" autocomplete="off">
    </div>
    <div class="chip-row" id="categoryChips"></div>
    <div class="meta-counts" id="metaCounts">Not connected</div>
  </section>

  <section class="content-grid">
    <div class="cards-grid" id="cardsGrid">
      <div class="empty-state" id="emptyState">
        <h3>Nothing on the scope yet</h3>
        <p>Press <strong>Start scanning</strong> to connect to Deriv's live feed and start tracking Volatility indices for Coil &amp; Breakout setups — a move into the EMA50, a tight consolidation straddling it, then a sharp expansion out of the range.</p>
      </div>
    </div>

    <aside class="feed-panel">
      <h2>Signal feed <span class="count" id="feedCount"></span></h2>
      <p class="feed-sub">Previews (watching) and confirmed entries appear here in real time.</p>
      <div class="feed-list" id="feedList">
        <div class="feed-empty">No signals yet.</div>
      </div>
    </aside>
  </section>
</main>

<div class="toast-container" id="toastContainer"></div>

<div class="modal-overlay" id="settingsModal" hidden>
  <div class="modal">
    <h2>Scanner settings</h2>
    <p class="modal-sub">Strategy parameters apply the next time you start scanning.</p>

    <div class="field-group">
      <span class="field-label">Connection</span>
      <div class="field">
        <label for="cfgAppId">Deriv app_id</label>
        <input type="text" id="cfgAppId" placeholder="1089">
      </div>
    </div>

    <div class="field-group">
      <span class="field-label">Detection timeframe</span>
      <div class="field">
        <label for="cfgTimeframe">Coil &amp; breakout candles</label>
        <select id="cfgTimeframe">
          <option value="M5">5 minutes</option>
          <option value="M15">15 minutes</option>
          <option value="M30">30 minutes</option>
          <option value="H1">1 hour</option>
        </select>
      </div>
      <p class="hint">The impulse/coil/breakout pattern is detected entirely on this timeframe. H1 and H4 are always fetched too, but only to drive the Bull/Bear/Mixed context badges on each card.</p>
    </div>

    <div class="field-group">
      <span class="field-label">Reference indicators</span>
      <div class="field-row">
        <div class="field"><label for="cfgEma20">H1/H4 EMA fast (context only)</label><input type="number" id="cfgEma20" min="2"></div>
        <div class="field"><label for="cfgEma50">EMA50 (coil reference)</label><input type="number" id="cfgEma50" min="2"></div>
      </div>
      <div class="field-row">
        <div class="field"><label for="cfgEma200">H1/H4 EMA slow (context only)</label><input type="number" id="cfgEma200" min="2"></div>
        <div class="field"><label for="cfgAtrPeriod">ATR period</label><input type="number" id="cfgAtrPeriod" min="2"></div>
      </div>
      <p class="hint">The H1/H4 EMAs only drive the Bull/Bear/Mixed badges on each card for context — the coil pattern itself is detected purely on price action around EMA50 on your chosen detection timeframe.</p>
    </div>

    <div class="field-group">
      <span class="field-label">Impulse into the EMA50</span>
      <div class="field-row">
        <div class="field"><label for="cfgImpulseLookback">Lookback candles</label><input type="number" id="cfgImpulseLookback" min="2"></div>
        <div class="field"><label for="cfgImpulseAtrMult">Min swing (× ATR)</label><input type="number" step="0.1" id="cfgImpulseAtrMult" min="0"></div>
      </div>
      <p class="hint">Requires price to have swung at least this many ATRs away from EMA50 shortly before the coil forms — filters out random chop with no prior move to exhaust.</p>
    </div>

    <div class="field-group">
      <span class="field-label">Coil / compression</span>
      <div class="field-row">
        <div class="field"><label for="cfgCoilLookback">Box width (candles)</label><input type="number" id="cfgCoilLookback" min="2"></div>
        <div class="field"><label for="cfgCompressionAtrMult">Max box range (× ATR)</label><input type="number" step="0.1" id="cfgCompressionAtrMult" min="0"></div>
      </div>
      <div class="field">
        <label for="cfgMaxCoilBars">Max candles to wait for a breakout</label>
        <input type="number" id="cfgMaxCoilBars" min="1">
      </div>
      <p class="hint">A coil is valid while the last N candles stay inside a tight range that straddles EMA50. Times out and resets if no breakout fires within the max wait. Rule of thumb: pure random chop over N candles naturally spans roughly √N × ATR (≈2.8× for 8 candles), so setting this near or below that number means almost nothing will ever qualify — keep it comfortably below √N but not drastically so.</p>
    </div>

    <div class="field-group">
      <span class="field-label">Breakout confirmation</span>
      <div class="field-row">
        <div class="field"><label for="cfgBreakoutAtrMult">Break buffer (× ATR)</label><input type="number" step="0.05" id="cfgBreakoutAtrMult" min="0"></div>
        <div class="field"><label for="cfgBreakoutExpansionMult">Range expansion (× coil avg)</label><input type="number" step="0.1" id="cfgBreakoutExpansionMult" min="0"></div>
      </div>
      <p class="hint">A candle must close beyond the box edge by the buffer AND have a range at least this multiple of the coil's average candle range — confirms a decisive break rather than a stray tick.</p>
    </div>

    <div class="field-group">
      <span class="field-label">Take-profit / stop-loss</span>
      <div class="field-row">
        <div class="field"><label for="cfgTpAtrMult">TP (× ATR)</label><input type="number" step="0.1" id="cfgTpAtrMult" min="0"></div>
        <div class="field"><label for="cfgSlAtrMult">SL (× ATR)</label><input type="number" step="0.1" id="cfgSlAtrMult" min="0"></div>
      </div>
      <div class="field">
        <label for="cfgMaxBarsTrack">Max candles to track before timeout</label>
        <input type="number" id="cfgMaxBarsTrack" min="1">
      </div>
      <p class="hint">Once a signal confirms, TP/SL is set as a multiple of that symbol's ATR (on the detection timeframe) at the time. Tracked only in this browser tab's memory — closing the tab drops anything still open.</p>
    </div>

    <div class="divider"></div>

    <div class="field-group">
      <span class="field-label">Alerts</span>
      <label class="checkbox-row"><input type="checkbox" id="cfgSound"> Play a sound on new buy/sell signals</label>
      <label class="checkbox-row"><input type="checkbox" id="cfgPullbackSound"> Play a separate sound when a setup starts watching</label>

      <div class="field-row">
        <div class="field">
          <label for="cfgSoundStyleWatching">Watching sound</label>
          <div class="sound-style-inline">
            <select id="cfgSoundStyleWatching">
              <option value="chime">Chime</option>
              <option value="beep">Beep</option>
              <option value="alert">Alert</option>
            </select>
            <button type="button" class="btn btn-icon btn-test" data-test-kind="pullback" title="Preview sound">▶</button>
          </div>
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label for="cfgSoundStyleBuy">Buy signal sound</label>
          <div class="sound-style-inline">
            <select id="cfgSoundStyleBuy">
              <option value="chime">Chime</option>
              <option value="beep">Beep</option>
              <option value="alert">Alert</option>
            </select>
            <button type="button" class="btn btn-icon btn-test" data-test-kind="buy" title="Preview sound">▶</button>
          </div>
        </div>
        <div class="field">
          <label for="cfgSoundStyleSell">Sell signal sound</label>
          <div class="sound-style-inline">
            <select id="cfgSoundStyleSell">
              <option value="chime">Chime</option>
              <option value="beep">Beep</option>
              <option value="alert">Alert</option>
            </select>
            <button type="button" class="btn btn-icon btn-test" data-test-kind="sell" title="Preview sound">▶</button>
          </div>
        </div>
      </div>

      <label class="checkbox-row"><input type="checkbox" id="cfgBrowserNotif"> Show browser notifications</label>
    </div>

    <div class="modal-actions">
      <button class="btn" id="closeSettingsBtn">Cancel</button>
      <button class="btn btn-primary" id="saveSettingsBtn">Save settings</button>
    </div>
  </div>
</div>

<script>
(function(){
  "use strict";

  // ==========================================================================
  // CONFIG
  // ==========================================================================
  const DEFAULTS = {
    appId: '1089',
    timeframe: 'M15',
    ema20: 20, ema50: 50, ema200: 200,
    atrPeriod: 14,
    coilLookback: 8, compressionAtrMult: 2.0,
    impulseLookback: 12, impulseAtrMult: 2.5,
    breakoutAtrMult: 0.15, breakoutExpansionMult: 1.6, maxCoilBars: 12,
    tpAtrMult: 2.0, slAtrMult: 1.0, maxBarsTrack: 20,
    soundEnabled: true, pullbackSoundEnabled: false, browserNotif: false,
    soundStyleWatching: 'chime', soundStyleBuy: 'chime', soundStyleSell: 'chime'
  };
  const STORAGE_KEY = 'signalScanSettings_v1';
  let CFG = loadSettings();

  function loadSettings(){
    try{
      const raw = localStorage.getItem(STORAGE_KEY);
      if(raw){
        const parsed = JSON.parse(raw);
        delete parsed.allowMixedH1;
        delete parsed.trendMode;
        delete parsed.atrMult;
        delete parsed.minPullback;
        return Object.assign({}, DEFAULTS, parsed);
      }
    }catch(e){ /* ignore */ }
    return Object.assign({}, DEFAULTS);
  }
  function persistSettings(){
    try{ localStorage.setItem(STORAGE_KEY, JSON.stringify(CFG)); }catch(e){ /* ignore */ }
  }

  const GRAN = { M5: 300, M15: 900, M30: 1800, H1: 3600, H4: 14400 };
  const HISTORY_COUNT = 300;

  // The primary detection timeframe is user-selectable (5m/15m/30m/1h); H1
  // and H4 are always fetched too, purely for the context trend badges.
  // If the person picks H1 as their primary, it naturally reuses the same
  // H1 candles for both roles instead of double-subscribing.
  function primaryGranularity(){
    return GRAN[CFG.timeframe] || GRAN.M15;
  }
  function neededGranularities(){
    return [...new Set([primaryGranularity(), GRAN.H1, GRAN.H4])];
  }

  const WHITELIST = {
    volatility: [10, 25, 50, 75, 100],
    volatilityOneSec: [10, 15, 25, 30, 50, 75, 90, 100, 150, 250]
  };

  // ==========================================================================
  // STATE
  // ==========================================================================
  let ws = null;
  let SYMBOLS = [];
  const DATA = {};
  let requestQueue = [];
  let queueRunning = false;
  let reconnectAttempts = 0;
  let manualStop = true;
  let pingHandle = null;
  let renderScheduled = false;
  let feedItems = [];
  const SIGNAL_TTL_MS = 6 * 60 * 60 * 1000; // signals live in the feed for 6 hours
  let counts = { buy: 0, sell: 0, preview: 0 };
  let searchQuery = '';
  let activeCategory = 'all';
  let flashTimers = {};
  // Outcome tracking for confirmed buy/sell signals — entirely in-memory,
  // reset on Stop or page reload (there's no backend here to persist to).
  // { symbol, direction, entry, tp, sl, mfe, mae, bars, feedItem } — feedItem
  // is a direct reference into feedItems so resolving a position can update
  // its badge/TP-SL line in place without a lookup.
  let openPositions = [];

  // ==========================================================================
  // DOM refs
  // ==========================================================================
  const $ = (id) => document.getElementById(id);
  const statusPill = $('statusPill');
  const statusText = $('statusText');
  const startBtn = $('startBtn');
  const stopBtn = $('stopBtn');
  const settingsBtn = $('settingsBtn');
  const cardsGrid = $('cardsGrid');
  const emptyState = $('emptyState');
  const feedList = $('feedList');
  const feedCount = $('feedCount');
  const metaCounts = $('metaCounts');
  const categoryChips = $('categoryChips');
  const searchInput = $('searchInput');
  const toastContainer = $('toastContainer');
  const settingsModal = $('settingsModal');

  const CATEGORIES = [
    { key: 'all', label: 'All' },
    { key: 'volatility', label: 'Volatility' }
  ];
  CATEGORIES.forEach(c => {
    const chip = document.createElement('button');
    chip.className = 'chip' + (c.key === 'all' ? ' active' : '');
    chip.textContent = c.label;
    chip.dataset.key = c.key;
    chip.addEventListener('click', () => {
      activeCategory = c.key;
      [...categoryChips.children].forEach(el => el.classList.toggle('active', el.dataset.key === c.key));
      scheduleRender();
    });
    categoryChips.appendChild(chip);
  });

  searchInput.addEventListener('input', () => {
    searchQuery = searchInput.value.trim().toLowerCase();
    scheduleRender();
  });

  // Open the matching TradingView chart when a card is activated (click or keyboard)
  function openChartForCard(cardEl){
    if(!cardEl) return;
    const symbol = cardEl.dataset.symbol;
    const item = SYMBOLS.find(s => s.symbol === symbol);
    if(!item) return;
    const url = tvUrlFor(item);
    if(url) window.open(url, '_blank', 'noopener');
  }
  cardsGrid.addEventListener('click', (e) => {
    const card = e.target.closest('.card[data-symbol]');
    if(card && !card.classList.contains('skeleton')) openChartForCard(card);
  });
  cardsGrid.addEventListener('keydown', (e) => {
    if(e.key !== 'Enter' && e.key !== ' ') return;
    const card = e.target.closest('.card[data-symbol]');
    if(card && !card.classList.contains('skeleton')){
      e.preventDefault();
      openChartForCard(card);
    }
  });

  // ==========================================================================
  // TOASTS
  // ==========================================================================
  function toast(msg, kind){
    const el = document.createElement('div');
    el.className = 'toast' + (kind ? ' ' + kind : '');
    el.textContent = msg;
    toastContainer.appendChild(el);
    setTimeout(() => {
      el.style.transition = 'opacity .3s ease';
      el.style.opacity = '0';
      setTimeout(() => el.remove(), 320);
    }, 4200);
  }

  // ==========================================================================
  // SOUND
  // ==========================================================================
  let audioCtx = null;

  // Generic envelope-shaped oscillator note. attack/dur in seconds, peakGain 0-1.
  function playTone(ctx, freq, type, attack, dur, peakGain){
    try{
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.type = type;
      osc.frequency.value = freq;
      gain.gain.setValueAtTime(0.0001, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(peakGain, ctx.currentTime + attack);
      gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + dur);
      osc.connect(gain).connect(ctx.destination);
      osc.start();
      osc.stop(ctx.currentTime + dur + 0.02);
    }catch(e){ /* audio unavailable */ }
  }

  // Each style renders `freq` for a single event, or a two/three-note
  // pattern when `layered` is true (used for buy/sell; watching stays a
  // single note regardless of style so it reads as lighter-weight).
  const SOUND_STYLES = {
    chime(ctx, freq, layered){
      playTone(ctx, freq, 'sine', 0.02, 0.32, 0.18);
      if(layered){
        setTimeout(() => playTone(ctx, freq * 1.25, 'sine', 0.02, 0.30, 0.16), 130);
      }
    },
    beep(ctx, freq, layered){
      playTone(ctx, freq, 'square', 0.005, 0.12, 0.12);
      if(layered){
        setTimeout(() => playTone(ctx, freq * 1.5, 'square', 0.005, 0.12, 0.12), 90);
      }
    },
    alert(ctx, freq, layered){
      const notes = layered ? 3 : 2;
      for(let i = 0; i < notes; i++){
        setTimeout(() => playTone(ctx, freq, 'triangle', 0.005, 0.09, 0.15), i * 140);
      }
    }
  };

  // kind: 'pullback' (watching), 'buy', 'sell'. Anything else falls back to
  // a plain chime gated by the general sound toggle.
  function playSound(kind){
    let freq, styleKey, layered;
    if(kind === 'pullback'){
      if(!CFG.pullbackSoundEnabled) return;
      freq = 392; styleKey = CFG.soundStyleWatching; layered = false;
    } else if(kind === 'buy'){
      if(!CFG.soundEnabled) return;
      freq = 880; styleKey = CFG.soundStyleBuy; layered = true;
    } else if(kind === 'sell'){
      if(!CFG.soundEnabled) return;
      freq = 523; styleKey = CFG.soundStyleSell; layered = true;
    } else {
      if(!CFG.soundEnabled) return;
      freq = 660; styleKey = 'chime'; layered = false;
    }
    try{
      audioCtx = audioCtx || new (window.AudioContext || window.webkitAudioContext)();
      const render = SOUND_STYLES[styleKey] || SOUND_STYLES.chime;
      render(audioCtx, freq, layered);
    }catch(e){ /* audio unavailable */ }
  }

  // Preview buttons bypass the enable checkboxes so you can audition a
  // style even while that alert type is currently turned off.
  function previewSound(kind, styleKey){
    const freq = kind === 'buy' ? 880 : kind === 'sell' ? 523 : 392;
    const layered = kind !== 'pullback';
    try{
      audioCtx = audioCtx || new (window.AudioContext || window.webkitAudioContext)();
      const render = SOUND_STYLES[styleKey] || SOUND_STYLES.chime;
      render(audioCtx, freq, layered);
    }catch(e){ /* audio unavailable */ }
  }

  function browserNotify(title, body){
    if(!CFG.browserNotif) return;
    if(typeof Notification === 'undefined') return;
    if(Notification.permission === 'granted'){
      try{ new Notification(title, { body }); }catch(e){}
    }
  }

  // ==========================================================================
  // SYMBOL RESOLUTION
  // ==========================================================================
  function classifySymbol(entry){
    const name = entry.display_name || '';
    const market = entry.market || '';
    if(market !== 'synthetic_index') return null;
    let m;
    if((m = name.match(/^Volatility\s+(\d+(?:\.\d+)?)\s*\(1s\)\s*Index$/i))){
      return { type: 'volatility', oneSec: true, num: parseFloat(m[1]) };
    }
    if((m = name.match(/^Volatility\s+(\d+(?:\.\d+)?)\s*Index$/i))){
      return { type: 'volatility', oneSec: false, num: parseFloat(m[1]) };
    }
    return null;
  }

  function buildSymbolList(activeSymbols){
    const found = { volatility: [] };
    activeSymbols.forEach((entry) => {
      const c = classifySymbol(entry);
      if(!c || c.type !== 'volatility') return;
      const item = { symbol: entry.symbol, display_name: entry.display_name, ...c };
      const whitelisted = c.oneSec ? WHITELIST.volatilityOneSec.includes(c.num) : WHITELIST.volatility.includes(c.num);
      if(whitelisted) found.volatility.push({ ...item, cat: 'volatility' });
    });

    const out = [];
    const seen = new Set();
    function push(symbol, label, cat, type, num, oneSec){
      if(seen.has(symbol)) return;
      seen.add(symbol);
      out.push({ symbol, label, cat, type, num, oneSec });
    }

    found.volatility.sort((a, b) => a.num - b.num || (a.oneSec === b.oneSec ? 0 : a.oneSec ? 1 : -1))
      .forEach(i => push(i.symbol, i.display_name, 'volatility', i.type, i.num, i.oneSec));

    return out;
  }

  // Maps our internal symbol classification to TradingView's DERIV: ticker
  // e.g. Volatility 75 -> DERIV:VOLATILITY_75_INDEX, Volatility 75(1s) -> DERIV:VOLATILITY_75_1S_INDEX
  function tvSymbolFor(item){
    if(!item) return null;
    const n = item.num;
    const numStr = Number.isInteger(n) ? String(n) : String(n);
    if(item.type === 'volatility'){
      return item.oneSec ? `VOLATILITY_${numStr}_1S_INDEX` : `VOLATILITY_${numStr}_INDEX`;
    }
    return null;
  }

  function tvUrlFor(item){
    const sym = tvSymbolFor(item);
    if(!sym) return null;
    return `https://www.tradingview.com/chart/?symbol=DERIV%3A${encodeURIComponent(sym)}`;
  }

  // ==========================================================================
  // WEBSOCKET
  // ==========================================================================
  function setStatus(state, label){
    statusPill.dataset.state = state;
    statusText.textContent = label || ({
      offline: 'Offline', connecting: 'Connecting…', live: 'Live', reconnecting: 'Reconnecting…'
    }[state] || state);
  }

  function connect(){
    manualStop = false;
    setStatus('connecting');
    const appId = (CFG.appId || '1089').trim() || '1089';
    ws = new WebSocket(`wss://ws.derivws.com/websockets/v3?app_id=${encodeURIComponent(appId)}`);

    ws.onopen = () => {
      reconnectAttempts = 0;
      setStatus('live');
      if(SYMBOLS.length === 0){
        wsSend({ active_symbols: 'brief', product_type: 'basic' });
      } else {
        SYMBOLS.forEach(s => enqueueSymbolRequests(s.symbol));
        runQueue();
      }
      startPing();
    };

    ws.onmessage = (ev) => {
      let msg;
      try{ msg = JSON.parse(ev.data); }catch(e){ return; }
      handleMessage(msg);
    };

    ws.onerror = () => { /* onclose will follow */ };

    ws.onclose = () => {
      stopPing();
      if(!manualStop){
        setStatus('reconnecting');
        scheduleReconnect();
      } else {
        setStatus('offline');
      }
    };
  }

  function disconnect(){
    manualStop = true;
    reconnectAttempts = 0;
    requestQueue = [];
    queueRunning = false;
    if(ws){ try{ ws.close(); }catch(e){} }
    stopPing();
    setStatus('offline');
  }

  function scheduleReconnect(){
    reconnectAttempts++;
    const delay = Math.min(1000 * Math.pow(1.6, reconnectAttempts), 20000);
    setTimeout(() => { if(!manualStop) connect(); }, delay);
  }

  function startPing(){
    stopPing();
    pingHandle = setInterval(() => wsSend({ ping: 1 }), 28000);
  }
  function stopPing(){
    if(pingHandle){ clearInterval(pingHandle); pingHandle = null; }
  }

  function wsSend(payload){
    if(ws && ws.readyState === WebSocket.OPEN){
      ws.send(JSON.stringify(payload));
      return true;
    }
    return false;
  }

  function enqueueSymbolRequests(symbol){
    neededGranularities().forEach(granularity => {
      requestQueue.push({ symbol, granularity });
    });
  }

  function runQueue(){
    if(queueRunning) return;
    queueRunning = true;
    const step = () => {
      if(requestQueue.length === 0){ queueRunning = false; return; }
      const job = requestQueue.shift();
      wsSend({
        ticks_history: job.symbol,
        style: 'candles',
        granularity: job.granularity,
        count: HISTORY_COUNT,
        end: 'latest',
        subscribe: 1
      });
      setTimeout(step, 220);
    };
    step();
  }

  // ==========================================================================
  // MESSAGE HANDLING
  // ==========================================================================
  function handleMessage(msg){
    if(msg.error){
      const req = msg.echo_req || {};
      if(req.ticks_history) console.error('[api error]', req.ticks_history, msg.error.message);
      else { toast(msg.error.message || 'Deriv API error', 'error'); setStatus('offline'); manualStop = true; }
      return;
    }

    if(msg.msg_type === 'active_symbols'){
      SYMBOLS = buildSymbolList(msg.active_symbols || []);
      SYMBOLS.forEach(s => initSymbolData(s.symbol, s.label));
      toast(`Connected — tracking ${SYMBOLS.length} instruments`, 'success');
      scheduleRender();
      SYMBOLS.forEach(s => enqueueSymbolRequests(s.symbol));
      runQueue();
      return;
    }

    if(msg.msg_type === 'candles'){
      const req = msg.echo_req || {};
      const symbol = req.ticks_history;
      const granularity = req.granularity;
      const sd = DATA[symbol];
      if(!sd || !msg.candles) return;
      sd.candles[granularity] = msg.candles.map(c => ({ epoch: c.epoch, open: +c.open, high: +c.high, low: +c.low, close: +c.close }));
      recomputeTimeframe(symbol, granularity);
      scheduleRender();
      return;
    }

    if(msg.msg_type === 'ohlc'){
      const o = msg.ohlc;
      if(!o) return;
      const symbol = o.symbol;
      const granularity = +o.granularity;
      const sd = DATA[symbol];
      if(!sd) return;
      const arr = sd.candles[granularity];
      if(!arr || arr.length === 0) return;

      const last = arr[arr.length - 1];
      const candle = { epoch: +o.open_time, open: +o.open, high: +o.high, low: +o.low, close: +o.close };

      if(last.epoch === candle.epoch){
        arr[arr.length - 1] = candle;
      } else if(candle.epoch > last.epoch){
        arr.push(candle);
        if(arr.length > HISTORY_COUNT + 5) arr.shift();
      } else {
        return;
      }

      const justClosed = last.epoch !== candle.epoch;
      recomputeTimeframe(symbol, granularity, justClosed ? last : null);
      scheduleRender();
    }
  }

  // ==========================================================================
  // SYMBOL DATA MODEL
  // ==========================================================================
  function initSymbolData(symbol, label){
    DATA[symbol] = {
      symbol, label,
      candles: {}, // keyed by raw granularity (seconds) — see neededGranularities()
      ind: {
        h1: { ema20: null, ema50: null, ema200: null, trend: 'mixed' },
        h4: { ema20: null, ema50: null, ema200: null, trend: 'mixed' },
        primary: { ema50: null, atr: null }
      },
      price: null,
      coil: newCoilState(),
      lastSignal: null,
      // Mirrors the entry in openPositions for this symbol (or null), kept
      // in sync by fireSignal()/updateOpenPositions() purely for cardHTML.
      openPosition: null,
      // Phase tracking for status-sort: stageKey is a combo of direction+stage
      // (a direction flip counts as a phase change too), phaseChangedAt is
      // used to rank newest movers to the top within the same tier.
      stageKey: null,
      phaseChangedAt: 0
    };
  }

  // A coil is the "circled" consolidation in the pattern: price swings hard
  // into EMA50 (the impulse), then chops in a tight box straddling it. Once
  // mature it's "watching" for a breakout; a decisive close outside the box
  // with an expanded range fires the signal. direction is unknown until the
  // box actually breaks — could resolve either bullish or bearish.
  function newCoilState(){
    return {
      active: false,      // currently inside a valid, still-forming/mature box
      matured: false,     // box has stood for coilLookback candles -> preview fired
      boxHigh: null, boxLow: null, avgRange: null,
      staleBars: 0         // candles elapsed since maturity without a breakout
    };
  }

  // ==========================================================================
  // INDICATORS
  // ==========================================================================
  function computeEMASeries(closes, period){
    if(closes.length < period) return new Array(closes.length).fill(null);
    const k = 2 / (period + 1);
    const out = new Array(closes.length).fill(null);
    let seed = 0;
    for(let i = 0; i < period; i++) seed += closes[i];
    seed /= period;
    out[period - 1] = seed;
    let prev = seed;
    for(let i = period; i < closes.length; i++){
      const val = closes[i] * k + prev * (1 - k);
      out[i] = val;
      prev = val;
    }
    return out;
  }

  function computeATRSeries(candles, period){
    const n = candles.length;
    const out = new Array(n).fill(null);
    if(n < period + 1) return out;
    const tr = new Array(n).fill(null);
    for(let i = 1; i < n; i++){
      const c = candles[i], p = candles[i - 1];
      tr[i] = Math.max(c.high - c.low, Math.abs(c.high - p.close), Math.abs(c.low - p.close));
    }
    let seed = 0;
    for(let i = 1; i <= period; i++) seed += tr[i];
    seed /= period;
    out[period] = seed;
    let prev = seed;
    for(let i = period + 1; i < n; i++){
      const val = (prev * (period - 1) + tr[i]) / period;
      out[i] = val;
      prev = val;
    }
    return out;
  }

  function trendFromEma(ema20, ema50, ema200, price){
    if(ema20 === null || ema50 === null || ema200 === null) return 'mixed';
    if(ema20 > ema50 && ema50 > ema200 && price > ema200) return 'bullish';
    if(ema20 < ema50 && ema50 < ema200 && price < ema200) return 'bearish';
    return 'mixed';
  }

  function recomputeTimeframe(symbol, granularity, justClosedCandle){
    const sd = DATA[symbol];
    if(!sd) return;
    const candles = sd.candles[granularity];
    if(!candles || candles.length === 0) return;
    const closes = candles.map(c => c.close);
    const lastClose = closes[closes.length - 1];

    const isPrimary = granularity === primaryGranularity();
    const isH1 = granularity === GRAN.H1;
    const isH4 = granularity === GRAN.H4;

    if(isPrimary) sd.price = lastClose;
    else if(sd.price == null) sd.price = lastClose;

    // Context badges (H1/H4). Note isH1/isH4 aren't mutually exclusive with
    // isPrimary — e.g. picking "1 hour" as the primary timeframe reuses this
    // same candle set for both the H1 badge and the coil detector below.
    if(isH1 || isH4){
      const e20 = computeEMASeries(closes, CFG.ema20);
      const e50b = computeEMASeries(closes, CFG.ema50);
      const e200 = computeEMASeries(closes, CFG.ema200);
      const i = closes.length - 1;
      const ema20 = e20[i], ema50 = e50b[i], ema200 = e200[i];
      const key = isH1 ? 'h1' : 'h4';
      sd.ind[key] = { ema20, ema50, ema200, trend: trendFromEma(ema20, ema50, ema200, lastClose) };
    }

    // Coil detection always runs on the selected primary timeframe.
    if(isPrimary){
      const e50 = computeEMASeries(closes, CFG.ema50);
      const atrArr = computeATRSeries(candles, CFG.atrPeriod);
      const i = closes.length - 1;
      sd.ind.primary.ema50 = e50[i];
      sd.ind.primary.atr = atrArr[i];

      if(justClosedCandle){
        const idxClosed = candles.length - 2;
        const emaAtClose = e50[idxClosed];
        const atrAtClose = atrArr[idxClosed];
        if(emaAtClose !== null && atrAtClose !== null && idxClosed >= 0){
          evaluateCoil(symbol, candles, e50, atrArr, idxClosed);
        }
        updateOpenPositions(symbol, justClosedCandle);
      }
    }

    updateStageTracking(symbol);
  }

  // Status-sort: tier order is coil (watching a mature box) > impulse
  // (recent swing, no box yet) > neutral. Called after every indicator/state
  // recompute so coil/impulse transitions register a phase change.
  function stageTier(stage){
    return { coil: 2, impulse: 1, neutral: 0 }[stage] ?? 0;
  }

  function updateStageTracking(symbol){
    const sd = DATA[symbol];
    if(!sd) return;
    const { direction, stage } = stageLabel(sd);
    const key = `${direction || ''}:${stage}`;
    if(sd.stageKey !== key){
      sd.stageKey = key;
      sd.phaseChangedAt = Date.now();
    }
  }

  // ==========================================================================
  // SIGNAL STATE MACHINE — Coil / Compression Breakout
  //
  // Matches the pattern: an impulsive swing carries price away from EMA50,
  // it then chops back and forth in a tight box that straddles EMA50 (the
  // "circled" consolidation), and finally a single candle explodes out of
  // that box with an expanded range — that candle is the signal, and its
  // direction (up or down) is only known at the moment of the break.
  // ==========================================================================
  function windowHighLow(candles, start, endInclusive){
    let hi = -Infinity, lo = Infinity, sum = 0;
    for(let i = start; i <= endInclusive; i++){
      const c = candles[i];
      if(c.high > hi) hi = c.high;
      if(c.low < lo) lo = c.low;
      sum += (c.high - c.low);
    }
    return { hi, lo, avgRange: sum / (endInclusive - start + 1) };
  }

  function maxDeviationFromEma(candles, start, endExclusive, ema){
    let m = 0;
    for(let i = start; i < endExclusive; i++){
      const c = candles[i];
      m = Math.max(m, Math.abs(c.high - ema), Math.abs(c.low - ema));
    }
    return m;
  }

  function evaluateCoil(symbol, candles, emaArr, atrArr, idxClosed){
    const sd = DATA[symbol];
    const coil = sd.coil;
    const closedCandle = candles[idxClosed];
    const ema = emaArr[idxClosed];
    const atr = atrArr[idxClosed];
    if(ema === null || atr === null || atr <= 0) return;

    const boxStart = idxClosed - CFG.coilLookback + 1;
    const impulseStart = boxStart - CFG.impulseLookback;

    // Recent-impulse flag drives the "Impulse" cascade segment even before a
    // box has formed — just informational context for the card.
    const recentStart = Math.max(0, idxClosed - CFG.impulseLookback - CFG.coilLookback + 1);
    coil.recentImpulse = maxDeviationFromEma(candles, recentStart, idxClosed + 1, ema) >= CFG.impulseAtrMult * atr;

    // --- Already watching a mature box: check for the breakout candle ---
    if(coil.matured){
      const bufferHigh = coil.boxHigh + CFG.breakoutAtrMult * atr;
      const bufferLow = coil.boxLow - CFG.breakoutAtrMult * atr;
      const brokeUp = closedCandle.close > bufferHigh;
      const brokeDown = closedCandle.close < bufferLow;
      const candleRange = closedCandle.high - closedCandle.low;
      const expanded = coil.avgRange > 0 && candleRange >= CFG.breakoutExpansionMult * coil.avgRange;

      if((brokeUp || brokeDown) && expanded){
        fireSignal(symbol, brokeUp ? 'buy' : 'sell', closedCandle, atr);
        resetCoil(coil);
        return;
      }

      coil.staleBars++;
      if(coil.staleBars > CFG.maxCoilBars){
        resetCoil(coil);
        invalidateFeedItem(symbol);
        return;
      }
      // Keep the box current while it's still genuinely tight, so a slowly
      // drifting range doesn't leave a stale, meaningless breakout level.
      if(boxStart >= 0){
        const w = windowHighLow(candles, boxStart, idxClosed);
        if(w.hi - w.lo <= CFG.compressionAtrMult * atr && w.lo <= ema && ema <= w.hi){
          coil.boxHigh = w.hi; coil.boxLow = w.lo; coil.avgRange = w.avgRange;
        }
      }
      return;
    }

    // --- Not yet watching: look for a fresh, mature coil ---
    if(boxStart < 0 || impulseStart < 0) return;
    const w = windowHighLow(candles, boxStart, idxClosed);
    const isTight = (w.hi - w.lo) <= CFG.compressionAtrMult * atr;
    const straddles = w.lo <= ema && ema <= w.hi;
    if(!isTight || !straddles){ coil.active = false; return; }

    const impulseOk = maxDeviationFromEma(candles, impulseStart, boxStart, ema) >= CFG.impulseAtrMult * atr;
    if(!impulseOk){ coil.active = false; return; }

    coil.active = true;
    coil.matured = true;
    coil.staleBars = 0;
    coil.boxHigh = w.hi;
    coil.boxLow = w.lo;
    coil.avgRange = w.avgRange;
    firePreview(symbol, closedCandle, coil);
  }

  function resetCoil(coil){
    coil.active = false;
    coil.matured = false;
    coil.boxHigh = null;
    coil.boxLow = null;
    coil.avgRange = null;
    coil.staleBars = 0;
  }

  function priceDigits(price){
    return price < 10 ? 5 : price < 1000 ? 3 : 2;
  }

  function firePreview(symbol, closedCandle, coil){
    const sd = DATA[symbol];
    const digits = priceDigits(closedCandle.close);
    const price = closedCandle.close.toFixed(digits);
    pushFeedItem({
      kind: 'preview', symbol, label: sd.label, direction: null, price,
      h1: sd.ind.h1.trend, h4: sd.ind.h4.trend, time: Date.now(),
      box: { high: coil.boxHigh.toFixed(digits), low: coil.boxLow.toFixed(digits) }
    });
    browserNotify(`Coil watching — ${sd.label}`, `Box ${coil.boxLow.toFixed(digits)}–${coil.boxHigh.toFixed(digits)} · awaiting breakout`);
    playSound('pullback');
  }

  function fireSignal(symbol, direction, closedCandle, atr){
    const sd = DATA[symbol];
    const digits = priceDigits(closedCandle.close);
    const entry = closedCandle.close;
    const price = entry.toFixed(digits);
    sd.lastSignal = { direction, price, time: Date.now() };
    counts[direction]++;

    const tp = direction === 'buy' ? entry + CFG.tpAtrMult * atr : entry - CFG.tpAtrMult * atr;
    const sl = direction === 'buy' ? entry - CFG.slAtrMult * atr : entry + CFG.slAtrMult * atr;

    const item = pushFeedItem({
      kind: direction, symbol, label: sd.label, direction, price,
      h1: sd.ind.h1.trend, h4: sd.ind.h4.trend, time: Date.now(),
      tp, sl, outcome: null, mfe: null, mae: null
    });

    const pos = { symbol, direction, entry, tp, sl, mfe: 0, mae: 0, bars: 0, feedItem: item };
    openPositions.push(pos);
    sd.openPosition = pos;

    flashCard(symbol, direction);
    browserNotify(`${direction.toUpperCase()} signal confirmed — ${sd.label}`, `Entry ${price}`);
    playSound(direction);
  }

  // Checks every open position against this symbol's just-closed primary-timeframe
  // candle: updates MFE/MAE, and resolves (tp/sl/timeout) once the price
  // touches either level or MAX_BARS_TRACK candles pass. If a candle
  // touches both TP and SL, SL wins — conservative, since we don't know
  // which was actually touched first intra-candle.
  function updateOpenPositions(symbol, closedCandle){
    if(openPositions.length === 0) return;
    const sd = DATA[symbol];
    const { high, low } = closedCandle;
    const remaining = [];
    for(const pos of openPositions){
      if(pos.symbol !== symbol){ remaining.push(pos); continue; }

      pos.bars++;
      const favorable = pos.direction === 'buy' ? high - pos.entry : pos.entry - low;
      const adverse = pos.direction === 'buy' ? pos.entry - low : high - pos.entry;
      if(favorable > pos.mfe) pos.mfe = favorable;
      if(adverse > pos.mae) pos.mae = adverse;

      const hitSl = pos.direction === 'buy' ? low <= pos.sl : high >= pos.sl;
      const hitTp = pos.direction === 'buy' ? high >= pos.tp : low <= pos.tp;

      let outcome = null;
      if(hitSl) outcome = 'sl';
      else if(hitTp) outcome = 'tp';
      else if(pos.bars >= CFG.maxBarsTrack) outcome = 'timeout';

      if(outcome){
        if(sd && sd.openPosition === pos) sd.openPosition = null;
        if(pos.feedItem){
          pos.feedItem.outcome = outcome;
          pos.feedItem.mfe = pos.mfe;
          pos.feedItem.mae = pos.mae;
        }
        const label = sd ? sd.label : symbol;
        if(outcome === 'tp') toast(`${label} hit TP`, 'success');
        else if(outcome === 'sl') toast(`${label} hit SL`, 'error');
        else toast(`${label} timed out (no TP/SL hit)`);
        browserNotify(`${label} ${outcome === 'tp' ? 'hit TP' : outcome === 'sl' ? 'hit SL' : 'timed out'}`, `${pos.direction.toUpperCase()} @ ${pos.entry.toFixed(priceDigits(pos.entry))}`);
      } else {
        remaining.push(pos);
      }
    }
    openPositions = remaining;
    scheduleRender();
  }

  function pushFeedItem(item){
    // A symbol only ever shows its latest status in the feed — if it already
    // has an entry (e.g. "Watching") and now flips to Buy/Sell (or vice versa),
    // drop the old one so the new one replaces it and jumps to the top.
    const idx = feedItems.findIndex(f => f.symbol === item.symbol);
    if(idx !== -1) feedItems.splice(idx, 1);
    item.expiresAt = Date.now() + SIGNAL_TTL_MS;
    feedItems.unshift(item);
    if(feedItems.length > 60) feedItems.length = 60;
    scheduleRender();
    return item;
  }

  // Removes a symbol's feed entry outright (used when a watched setup becomes
  // invalid before it ever confirms into a Buy/Sell signal).
  function invalidateFeedItem(symbol){
    const idx = feedItems.findIndex(f => f.symbol === symbol && f.kind === 'preview');
    if(idx !== -1){
      feedItems.splice(idx, 1);
      scheduleRender();
    }
  }

  // Drops any feed entries that have passed their 6hr TTL. Returns true if
  // anything was removed, so the caller knows whether a re-render is needed.
  function pruneExpiredFeedItems(){
    const now = Date.now();
    const before = feedItems.length;
    feedItems = feedItems.filter(f => !f.expiresAt || f.expiresAt > now);
    return feedItems.length !== before;
  }

  function flashCard(symbol, direction){
    if(flashTimers[symbol]) clearTimeout(flashTimers[symbol]);
    const el = document.querySelector(`[data-symbol="${cssEscape(symbol)}"]`);
    if(el) el.classList.add(direction === 'buy' ? 'flash-buy' : 'flash-sell');
    flashTimers[symbol] = setTimeout(() => {
      if(el){ el.classList.remove('flash-buy'); el.classList.remove('flash-sell'); }
    }, 6000);
  }

  function cssEscape(s){
    return String(s).replace(/[^a-zA-Z0-9_-]/g, '\\$&');
  }

  // ==========================================================================
  // RENDERING
  // ==========================================================================
  function scheduleRender(){
    if(renderScheduled) return;
    renderScheduled = true;
    requestAnimationFrame(() => {
      renderScheduled = false;
      renderCards();
      renderFeed();
      renderCounts();
    });
  }

  function stageLabel(sd){
    const coil = sd.coil;
    if(coil.matured) return { direction: null, stage: 'coil', progress: `${coil.staleBars}/${CFG.maxCoilBars} candles` };
    if(coil.recentImpulse) return { direction: null, stage: 'impulse', progress: '' };
    return { direction: null, stage: 'neutral', progress: '' };
  }

  function trendBadge(trend){
    const cls = trend === 'bullish' ? 'bullish' : trend === 'bearish' ? 'bearish' : 'mixed';
    const label = trend === 'bullish' ? 'Bull' : trend === 'bearish' ? 'Bear' : 'Mixed';
    return `<span class="badge ${cls}">${label}</span>`;
  }

  function cardHTML(item){
    const sd = DATA[item.symbol];
    if(!sd){
      return `<div class="card skeleton" data-symbol="${item.symbol}">
        <div class="card-top">
          <div><div class="card-label">${item.label}</div><div class="card-symbol">${item.symbol}</div></div>
          <div class="card-price">—</div>
        </div>
        <div class="badges">${trendBadge('mixed')}${trendBadge('mixed')}</div>
        <div class="cascade-labels"><span>Impulse</span><span>Coil</span><span>Breakout</span></div>
        <div class="cascade"><div class="stage s1"></div><div class="stage s2"></div><div class="stage s3"></div></div>
        <div class="card-footer"><span>Loading history…</span><span></span></div>
      </div>`;
    }
    const { stage, progress } = stageLabel(sd);
    const s1on = (stage === 'impulse' || stage === 'coil') ? 'on' : '';
    const s2on = (stage === 'coil') ? 'on' : '';
    const s3on = (stage === 'coil') ? 'on armed' : '';
    const price = sd.price != null ? sd.price.toFixed(priceDigits(sd.price)) : '—';
    const statusText = stage === 'coil' ? `Coiling at EMA50 — watching for breakout (${progress})`
      : stage === 'impulse' ? 'Impulse detected — waiting for compression'
      : 'No setup building';
    const statusCls = '';
    const lastSig = sd.lastSignal ? `Last: ${sd.lastSignal.direction.toUpperCase()} @ ${sd.lastSignal.price}` : 'No signals yet';
    const hasChart = !!tvSymbolFor(item);
    const pos = sd.openPosition;
    const posRow = pos
      ? `<div class="card-position"><span>TP <span class="tp">${pos.tp.toFixed(priceDigits(pos.tp))}</span></span><span>SL <span class="sl">${pos.sl.toFixed(priceDigits(pos.sl))}</span></span></div>`
      : '';

    return `<div class="card" data-symbol="${item.symbol}" ${hasChart ? 'tabindex="0" role="button"' : ''} title="${hasChart ? 'Open ' + sd.label + ' on TradingView' : ''}">
      <div class="card-top">
        <div><div class="card-label">${sd.label}</div><div class="card-symbol">${item.symbol}</div></div>
        <div>
          <div class="card-price">${price}</div>
          ${hasChart ? '<div class="chart-hint">View chart ↗</div>' : ''}
        </div>
      </div>
      <div class="badges">${trendBadge(sd.ind.h4.trend)}${trendBadge(sd.ind.h1.trend)}</div>
      <div class="cascade-labels"><span>Impulse</span><span>Coil</span><span>Breakout</span></div>
      <div class="cascade">
        <div class="stage s1 ${s1on}"></div>
        <div class="stage s2 ${s2on}"></div>
        <div class="stage s3 ${s3on}"></div>
      </div>
      <div class="card-footer">
        <span class="card-status-text ${statusCls}">${statusText}</span>
        <span>${lastSig}</span>
      </div>
      ${posRow}
    </div>`;
  }

  function filteredSymbols(){
    const list = SYMBOLS.filter(item => {
      if(activeCategory !== 'all' && item.cat !== activeCategory) return false;
      if(searchQuery && !item.label.toLowerCase().includes(searchQuery) && !item.symbol.toLowerCase().includes(searchQuery)) return false;
      return true;
    });
    return list.slice().sort((a, b) => {
      const sdA = DATA[a.symbol], sdB = DATA[b.symbol];
      const tierA = sdA ? stageTier(stageLabel(sdA).stage) : -1;
      const tierB = sdB ? stageTier(stageLabel(sdB).stage) : -1;
      if(tierA !== tierB) return tierB - tierA;
      const tA = sdA ? sdA.phaseChangedAt || 0 : 0;
      const tB = sdB ? sdB.phaseChangedAt || 0 : 0;
      if(tA !== tB) return tB - tA;
      return a.num - b.num || (a.oneSec === b.oneSec ? 0 : a.oneSec ? 1 : -1);
    });
  }

  function renderCards(){
    const list = filteredSymbols();
    if(SYMBOLS.length === 0){
      cardsGrid.innerHTML = '';
      cardsGrid.appendChild(emptyState);
      return;
    }
    if(list.length === 0){
      cardsGrid.innerHTML = `<div class="empty-state"><h3>No matches</h3><p>Try a different filter or clear the search.</p></div>`;
      return;
    }

    // FLIP animation: capture each card's current on-screen position before
    // we touch the DOM, so we can animate from old -> new position after
    // the status-sort reorders them.
    const prevRects = new Map();
    cardsGrid.querySelectorAll('.card[data-symbol]').forEach(el => {
      prevRects.set(el.dataset.symbol, el.getBoundingClientRect());
    });

    const existing = new Map();
    cardsGrid.querySelectorAll('.card[data-symbol]').forEach(el => {
      existing.set(el.dataset.symbol, el);
    });

    const frag = document.createDocumentFragment();
    const seen = new Set();
    list.forEach(item => {
      const temp = document.createElement('div');
      temp.innerHTML = cardHTML(item);
      const newEl = temp.firstElementChild;
      frag.appendChild(newEl);
      seen.add(item.symbol);
    });
    existing.forEach((el, symbol) => { if(!seen.has(symbol)) el.remove(); });

    cardsGrid.innerHTML = '';
    cardsGrid.appendChild(frag);

    // Invert + play: for any card whose position changed, snap it back to
    // where it used to be with a transform, then transition to identity.
    cardsGrid.querySelectorAll('.card[data-symbol]').forEach(el => {
      const symbol = el.dataset.symbol;
      const prev = prevRects.get(symbol);
      if(!prev) return;
      const next = el.getBoundingClientRect();
      const dx = prev.left - next.left;
      const dy = prev.top - next.top;
      if(!dx && !dy) return;
      el.style.transition = 'none';
      el.style.transform = `translate(${dx}px, ${dy}px)`;
      requestAnimationFrame(() => {
        el.style.transition = 'transform .35s ease';
        el.style.transform = '';
        el.addEventListener('transitionend', () => { el.style.transition = ''; }, { once: true });
      });
    });
  }

  function timeAgo(ts){
    const s = Math.max(0, Math.round((Date.now() - ts) / 1000));
    if(s < 60) return `${s}s ago`;
    const m = Math.round(s / 60);
    if(m < 60) return `${m}m ago`;
    const h = Math.round(m / 60);
    return `${h}h ago`;
  }

  function renderFeed(){
    feedCount.textContent = feedItems.length ? `(${feedItems.length})` : '';
    if(feedItems.length === 0){
      feedList.innerHTML = '<div class="feed-empty">No signals yet.</div>';
      return;
    }
    feedList.innerHTML = feedItems.slice(0, 40).map(f => {
      let tag, tagCls;
      if(f.kind === 'preview'){ tag = 'Watching'; tagCls = ''; }
      else if(f.outcome === 'tp'){ tag = 'WON'; tagCls = 'won'; }
      else if(f.outcome === 'sl'){ tag = 'LOST'; tagCls = 'lost'; }
      else if(f.outcome === 'timeout'){ tag = 'TIMEOUT'; tagCls = 'timeout'; }
      else { tag = f.direction.toUpperCase(); tagCls = ''; }
      const itemCls = f.outcome === 'timeout' ? 'timeout' : f.kind;
      const digits = priceDigits(Number(f.price));
      const tpSlRow = (f.tp != null && f.sl != null && !f.outcome)
        ? `<div class="feed-row3"><span class="tp">TP ${f.tp.toFixed(digits)}</span><span class="sl">SL ${f.sl.toFixed(digits)}</span></div>`
        : '';
      const boxRow = f.box
        ? `<div class="feed-row3"><span>Box ${f.box.low}–${f.box.high}</span></div>`
        : '';
      return `<div class="feed-item ${itemCls}">
        <div class="feed-row1"><span>${f.label}</span><span class="tag ${tagCls}">${tag}</span></div>
        <div class="feed-row2"><span>@ ${f.price}</span><span>${timeAgo(f.time)}</span></div>
        ${tpSlRow}${boxRow}
      </div>`;
    }).join('');
  }

  function renderCounts(){
    if(SYMBOLS.length === 0){ metaCounts.textContent = 'Not connected'; return; }
    metaCounts.textContent = `${filteredSymbols().length}/${SYMBOLS.length} instruments · ${counts.buy} buy · ${counts.sell} sell confirmed`;
  }

  // refresh "time ago" labels periodically without a full re-render storm,
  // and drop any signals that have aged past their 6hr TTL
  setInterval(() => {
    const pruned = pruneExpiredFeedItems();
    if(feedItems.length || pruned) renderFeed();
  }, 15000);

  // ==========================================================================
  // START / STOP
  // ==========================================================================
  startBtn.addEventListener('click', () => {
    startBtn.hidden = true;
    stopBtn.hidden = false;
    connect();
  });
  stopBtn.addEventListener('click', () => {
    disconnect();
    startBtn.hidden = false;
    stopBtn.hidden = true;
    SYMBOLS = [];
    Object.keys(DATA).forEach(k => delete DATA[k]);
    openPositions = [];
    scheduleRender();
    toast('Scanning stopped.');
  });

  // ==========================================================================
  // SETTINGS MODAL
  // ==========================================================================
  function openSettings(){
    $('cfgAppId').value = CFG.appId;
    $('cfgTimeframe').value = CFG.timeframe;
    $('cfgEma20').value = CFG.ema20;
    $('cfgEma50').value = CFG.ema50;
    $('cfgEma200').value = CFG.ema200;
    $('cfgAtrPeriod').value = CFG.atrPeriod;
    $('cfgImpulseLookback').value = CFG.impulseLookback;
    $('cfgImpulseAtrMult').value = CFG.impulseAtrMult;
    $('cfgCoilLookback').value = CFG.coilLookback;
    $('cfgCompressionAtrMult').value = CFG.compressionAtrMult;
    $('cfgMaxCoilBars').value = CFG.maxCoilBars;
    $('cfgBreakoutAtrMult').value = CFG.breakoutAtrMult;
    $('cfgBreakoutExpansionMult').value = CFG.breakoutExpansionMult;
    $('cfgTpAtrMult').value = CFG.tpAtrMult;
    $('cfgSlAtrMult').value = CFG.slAtrMult;
    $('cfgMaxBarsTrack').value = CFG.maxBarsTrack;
    $('cfgSound').checked = !!CFG.soundEnabled;
    $('cfgPullbackSound').checked = !!CFG.pullbackSoundEnabled;
    $('cfgSoundStyleWatching').value = CFG.soundStyleWatching;
    $('cfgSoundStyleBuy').value = CFG.soundStyleBuy;
    $('cfgSoundStyleSell').value = CFG.soundStyleSell;
    $('cfgBrowserNotif').checked = !!CFG.browserNotif;
    settingsModal.hidden = false;
  }
  function closeSettings(){ settingsModal.hidden = true; }

  settingsBtn.addEventListener('click', openSettings);
  $('closeSettingsBtn').addEventListener('click', closeSettings);
  settingsModal.addEventListener('click', (e) => { if(e.target === settingsModal) closeSettings(); });

  $('cfgBrowserNotif').addEventListener('change', (e) => {
    if(e.target.checked && typeof Notification !== 'undefined' && Notification.permission === 'default'){
      Notification.requestPermission();
    }
  });

  document.querySelectorAll('.btn-test[data-test-kind]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const kind = btn.getAttribute('data-test-kind');
      const selectId = kind === 'pullback' ? 'cfgSoundStyleWatching' : kind === 'buy' ? 'cfgSoundStyleBuy' : 'cfgSoundStyleSell';
      previewSound(kind, $(selectId).value);
    });
  });

  $('saveSettingsBtn').addEventListener('click', () => {
    const num = (id, fallback) => {
      const v = parseFloat($(id).value);
      return isNaN(v) ? fallback : v;
    };
    CFG = {
      appId: $('cfgAppId').value.trim() || '1089',
      timeframe: $('cfgTimeframe').value,
      ema20: num('cfgEma20', DEFAULTS.ema20),
      ema50: num('cfgEma50', DEFAULTS.ema50),
      ema200: num('cfgEma200', DEFAULTS.ema200),
      atrPeriod: num('cfgAtrPeriod', DEFAULTS.atrPeriod),
      impulseLookback: Math.max(2, Math.round(num('cfgImpulseLookback', DEFAULTS.impulseLookback))),
      impulseAtrMult: num('cfgImpulseAtrMult', DEFAULTS.impulseAtrMult),
      coilLookback: Math.max(2, Math.round(num('cfgCoilLookback', DEFAULTS.coilLookback))),
      compressionAtrMult: num('cfgCompressionAtrMult', DEFAULTS.compressionAtrMult),
      maxCoilBars: Math.max(1, Math.round(num('cfgMaxCoilBars', DEFAULTS.maxCoilBars))),
      breakoutAtrMult: num('cfgBreakoutAtrMult', DEFAULTS.breakoutAtrMult),
      breakoutExpansionMult: num('cfgBreakoutExpansionMult', DEFAULTS.breakoutExpansionMult),
      tpAtrMult: num('cfgTpAtrMult', DEFAULTS.tpAtrMult),
      slAtrMult: num('cfgSlAtrMult', DEFAULTS.slAtrMult),
      maxBarsTrack: Math.max(1, Math.round(num('cfgMaxBarsTrack', DEFAULTS.maxBarsTrack))),
      soundEnabled: $('cfgSound').checked,
      pullbackSoundEnabled: $('cfgPullbackSound').checked,
      soundStyleWatching: $('cfgSoundStyleWatching').value,
      soundStyleBuy: $('cfgSoundStyleBuy').value,
      soundStyleSell: $('cfgSoundStyleSell').value,
      browserNotif: $('cfgBrowserNotif').checked
    };
    persistSettings();
    closeSettings();
    toast('Settings saved. Restart scanning to apply new parameters.', 'success');
  });

  // ==========================================================================
  // INIT
  // ==========================================================================
  renderCounts();

  // Start scanning automatically on load
  startBtn.hidden = true;
  stopBtn.hidden = false;
  connect();
})();
</script>
</body>
</html>
